# dietmcp environment variables
# Copy this file to .env and fill in your values.
# These are referenced in servers.json via ${VAR_NAME} syntax.
#
# .env search order (later wins):
#   1. Shell environment variables
#   2. ~/.config/dietmcp/.env (or platform equivalent)
#   3. <project-root>/.env (this file, when copied to .env)
#   4. Current working directory .env
#   5. Custom path via "envFile" in config defaults

# ─── GitHub ───────────────────────────────────────────────
# GITHUB_PERSONAL_ACCESS_TOKEN=ghp_your_token_here

# ─── Brave Search ─────────────────────────────────────────
# BRAVE_API_KEY=your_brave_api_key

# ─── GitLab ───────────────────────────────────────────────
# GITLAB_PERSONAL_ACCESS_TOKEN=your_gitlab_token
# GITLAB_API_URL=https://gitlab.com/api/v4

# ─── Google Maps ──────────────────────────────────────────
# GOOGLE_MAPS_API_KEY=your_google_maps_key

# ─── Slack ────────────────────────────────────────────────
# SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
# SLACK_TEAM_ID=T00000000

# ─── Sentry ──────────────────────────────────────────────
# SENTRY_AUTH_TOKEN=your_sentry_auth_token
# SENTRY_ORG=your_sentry_org

# ─── Notion ──────────────────────────────────────────────
# NOTION_MCP_HEADERS={"Authorization":"Bearer your_notion_token","Notion-Version":"2022-06-28"}

# ─── Cloudflare ──────────────────────────────────────────
# CLOUDFLARE_API_TOKEN=your_cloudflare_token
# CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id

# ─── Stripe ──────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_test_your_stripe_key

# ─── Supabase ────────────────────────────────────────────
# SUPABASE_ACCESS_TOKEN=your_supabase_access_token

# ─── Railway ─────────────────────────────────────────────
# RAILWAY_API_TOKEN=your_railway_token

# ─── Heroku ──────────────────────────────────────────────
# HEROKU_API_KEY=your_heroku_key

# ─── MongoDB ─────────────────────────────────────────────
# MDB_MCP_CONNECTION_STRING=mongodb+srv://user:pass@cluster.mongodb.net/dbname

# ─── Apify ───────────────────────────────────────────────
# APIFY_TOKEN=your_apify_token

# ─── Figma ───────────────────────────────────────────────
# FIGMA_API_KEY=your_figma_api_key

# ─── 21st.dev Magic UI ──────────────────────────────────
# TWENTY_FIRST_API_KEY=your_21st_dev_key

# ─── Tavily ──────────────────────────────────────────────
# TAVILY_API_KEY=your_tavily_key

# ─── Firecrawl ───────────────────────────────────────────
# FIRECRAWL_API_KEY=your_firecrawl_key

# ─── Exa ─────────────────────────────────────────────────
# EXA_API_KEY=your_exa_key

# ─── EverArt ─────────────────────────────────────────────
# EVERART_API_KEY=your_everart_key

# ─── AWS (shared across all AWS MCP servers) ─────────────
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_REGION=us-east-1

# ─── Mapbox ──────────────────────────────────────────────
# MAPBOX_ACCESS_TOKEN=your_mapbox_token

# ─── HubSpot ─────────────────────────────────────────────
# HUBSPOT_ACCESS_TOKEN=your_hubspot_token

# ─── Postgres ────────────────────────────────────────────
# POSTGRES_URL=postgresql://user:pass@localhost:5432/dbname
